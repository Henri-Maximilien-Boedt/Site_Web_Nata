<!DOCTYPE html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= title %></title>
    <meta name="description" content="<%= description %>" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Manrope:wght@400;500;700;800&display=swap"
      rel="stylesheet"
    />
    <link rel="stylesheet" href="/css/main.css" />
  </head>
  <body>
    <div class="noise"></div>
    <%- include('partials/header', { currentPath: '/actualites' }) %>

    <main>
      <%
        const featured = Array.isArray(typeof featuredPosts !== 'undefined' ? featuredPosts : null) ? featuredPosts : []
        const upcoming = Array.isArray(typeof upcomingPosts !== 'undefined' ? upcomingPosts : null) ? upcomingPosts : []
        const past = Array.isArray(typeof pastPosts !== 'undefined' ? pastPosts : null) ? pastPosts : []
      %>
      <section class="story reveal">
        <div class="story-card">
          <p class="eyebrow">Actualités</p>
          <h2>Infos & Événements</h2>
          <p>Retrouve nos événements à la une, les prochains rendez-vous et ceux déjà passés.</p>
        </div>
      </section>

      <section class="news-section reveal">
        <div class="news-section-head">
          <p class="eyebrow">Section 1</p>
          <h2>Événements à la une</h2>
        </div>
        <% if (featured.length === 0) { %>
          <p class="news-empty">Aucun événement à la une pour le moment.</p>
        <% } else { %>
          <div class="news-grid">
            <% featured.forEach(post => { %>
              <a class="news-card news-card--pinned" href="/actualites/<%= post.id %>">
                <div class="news-card__img">
                  <% if (post.main_image_url) { %>
                    <img src="<%= post.main_image_url %>" alt="<%= post.title %>" loading="lazy" />
                  <% } else { %>
                    <div class="news-card__img-placeholder">NATA</div>
                  <% } %>
                  <span class="news-badge news-badge--event">Événement</span>
                  <span class="news-badge news-badge--pinned">À la une</span>
                </div>
                <div class="news-card__body">
                  <p class="news-card__date">
                    <%
                      const d = new Date(post.event_date || post.ref_date || post.created_at)
                      const formatted = d.toLocaleDateString('fr-BE', { day: 'numeric', month: 'long', year: 'numeric' })
                    %>
                    <%= formatted %>
                  </p>
                  <h3 class="news-card__title"><%= post.title %></h3>
                  <% if (post.content) { %>
                    <p class="news-card__excerpt"><%= post.content.replace(/<[^>]*>/g, '').slice(0, 120) %><% if (post.content.length > 120) { %>…<% } %></p>
                  <% } %>
                  <span class="news-card__cta">Lire la suite →</span>
                </div>
              </a>
            <% }) %>
          </div>
        <% } %>
      </section>

      <section class="news-section reveal">
        <div class="news-section-head">
          <p class="eyebrow">Section 2</p>
          <h2>Événements futurs</h2>
        </div>
        <% if (upcoming.length === 0) { %>
          <p class="news-empty">Aucun événement futur pour le moment.</p>
        <% } else { %>
          <div class="news-grid">
            <% upcoming.forEach(post => { %>
              <a class="news-card" href="/actualites/<%= post.id %>">
                <div class="news-card__img">
                  <% if (post.main_image_url) { %>
                    <img src="<%= post.main_image_url %>" alt="<%= post.title %>" loading="lazy" />
                  <% } else { %>
                    <div class="news-card__img-placeholder">NATA</div>
                  <% } %>
                  <span class="news-badge news-badge--event">Événement</span>
                </div>
                <div class="news-card__body">
                  <p class="news-card__date">
                    <%
                      const d = new Date(post.event_date || post.ref_date || post.created_at)
                      const formatted = d.toLocaleDateString('fr-BE', { day: 'numeric', month: 'long', year: 'numeric' })
                    %>
                    <%= formatted %>
                  </p>
                  <h3 class="news-card__title"><%= post.title %></h3>
                  <% if (post.content) { %>
                    <p class="news-card__excerpt"><%= post.content.replace(/<[^>]*>/g, '').slice(0, 120) %><% if (post.content.length > 120) { %>…<% } %></p>
                  <% } %>
                  <span class="news-card__cta">Lire la suite →</span>
                </div>
              </a>
            <% }) %>
          </div>
        <% } %>
      </section>

      <section class="news-section reveal">
        <div class="news-section-head">
          <p class="eyebrow">Section 3</p>
          <h2>Événements passés</h2>
        </div>
        <% if (past.length === 0) { %>
          <p class="news-empty">Aucun événement passé pour le moment.</p>
        <% } else { %>
          <div class="news-grid">
            <% past.forEach(post => { %>
              <a class="news-card" href="/actualites/<%= post.id %>">
                <div class="news-card__img">
                  <% if (post.main_image_url) { %>
                    <img src="<%= post.main_image_url %>" alt="<%= post.title %>" loading="lazy" />
                  <% } else { %>
                    <div class="news-card__img-placeholder">NATA</div>
                  <% } %>
                  <span class="news-badge news-badge--event">Événement</span>
                </div>
                <div class="news-card__body">
                  <p class="news-card__date">
                    <%
                      const d = new Date(post.event_date || post.ref_date || post.created_at)
                      const formatted = d.toLocaleDateString('fr-BE', { day: 'numeric', month: 'long', year: 'numeric' })
                    %>
                    <%= formatted %>
                  </p>
                  <h3 class="news-card__title"><%= post.title %></h3>
                  <% if (post.content) { %>
                    <p class="news-card__excerpt"><%= post.content.replace(/<[^>]*>/g, '').slice(0, 120) %><% if (post.content.length > 120) { %>…<% } %></p>
                  <% } %>
                  <span class="news-card__cta">Lire la suite →</span>
                </div>
              </a>
            <% }) %>
          </div>
        <% } %>
      </section>
    </main>

    <%- include('partials/footer') %>
    <script src="/js/app.js"></script>
  </body>
</html>
