<!DOCTYPE html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= title %></title>
    <meta name="description" content="<%= description %>" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Manrope:wght@400;500;700;800&display=swap"
      rel="stylesheet"
    />
    <link rel="stylesheet" href="/css/main.css" />
  </head>
  <body>
    <div class="noise"></div>
    <%- include('partials/header', { currentPath: '/actualites' }) %>

    <main>
      <section class="story reveal">
        <div class="story-card">
          <p class="eyebrow">Actualités</p>
          <h2>Infos & Événements</h2>
          <p>Les dernières nouvelles de NATA Bar : soirées spéciales, nouveautés et moments partagés.</p>
        </div>
      </section>

      <section class="news-section reveal">
        <% if (!posts || posts.length === 0) { %>
          <p class="news-empty">Aucune actualité pour le moment. Revenez bientôt !</p>
        <% } else { %>
          <div class="news-grid">
            <% posts.forEach(post => { %>
              <a class="news-card<%= post.is_pinned ? ' news-card--pinned' : '' %>" href="/actualites/<%= post.id %>">
                <div class="news-card__img">
                  <% if (post.main_image_url) { %>
                    <img src="<%= post.main_image_url %>" alt="<%= post.title %>" loading="lazy" />
                  <% } else { %>
                    <div class="news-card__img-placeholder">NATA</div>
                  <% } %>
                  <% if (post.event_date) { %>
                    <span class="news-badge news-badge--event">Événement</span>
                  <% } %>
                  <% if (post.is_pinned) { %>
                    <span class="news-badge news-badge--pinned">À la une</span>
                  <% } %>
                </div>
                <div class="news-card__body">
                  <% if (post.event_date) { %>
                    <p class="news-card__date">
                      <%
                        const d = new Date(post.event_date)
                        const formatted = d.toLocaleDateString('fr-BE', { day: 'numeric', month: 'long', year: 'numeric' })
                      %>
                      <%= formatted %>
                    </p>
                  <% } else { %>
                    <p class="news-card__date">
                      <%
                        const d = new Date(post.created_at)
                        const formatted = d.toLocaleDateString('fr-BE', { day: 'numeric', month: 'long', year: 'numeric' })
                      %>
                      <%= formatted %>
                    </p>
                  <% } %>
                  <h3 class="news-card__title"><%= post.title %></h3>
                  <% if (post.content) { %>
                    <p class="news-card__excerpt"><%= post.content.replace(/<[^>]*>/g, '').slice(0, 120) %><% if (post.content.length > 120) { %>…<% } %></p>
                  <% } %>
                  <span class="news-card__cta">Lire la suite →</span>
                </div>
              </a>
            <% }) %>
          </div>
        <% } %>
      </section>
    </main>

    <%- include('partials/footer') %>
    <script src="/js/app.js"></script>
  </body>
</html>
