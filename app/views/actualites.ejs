<!DOCTYPE html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= title %></title>
    <meta name="description" content="<%= description %>" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Manrope:wght@400;500;700;800&display=swap"
      rel="stylesheet"
    />
    <link rel="stylesheet" href="/css/main.css" />
  </head>
  <body>
    <div class="noise"></div>
    <%- include('partials/header', { currentPath: '/actualites' }) %>

    <main>
      <section class="story reveal" style="padding-top: 4rem;">
        <div class="story-card">
          <p class="eyebrow">Actualités</p>
          <h2>Infos NATA Bar</h2>
          <p>Cette page reste disponible et sera alimentée depuis l’admin.</p>
        </div>
      </section>
    </main>

    <%- include('partials/footer') %>

    <textarea id="nata-state" hidden><%- typeof clientStateJson !== 'undefined' ? clientStateJson : '{}' %></textarea>
    <script src="/js/app.js"></script>
  </body>
</html>
