<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Réservations — Admin NATA</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Manrope:wght@400;500;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/main.css">
  <link rel="stylesheet" href="/css/admin.css">
</head>
<body class="admin-page">
  <div class="noise"></div>
  <%- include('../partials/admin-topbar', { currentSection: 'reservations' }) %>
  <div class="admin-standalone">
    <div class="admin-page-head">
      <div>
        <p class="eyebrow">Admin</p>
        <h1>Réservations</h1>
      </div>
    </div>

    <% if (!reservations || reservations.length === 0) { %>
      <div class="admin-empty">
        <p>Aucune réservation confirmée à venir.</p>
      </div>
    <% } else { %>
      <div class="admin-posts-table-wrap">
        <table class="admin-posts-table">
          <thead>
            <tr>
              <th>Date</th>
              <th>Heure</th>
              <th>Table</th>
              <th>Client</th>
              <th>Couverts</th>
              <th>Source</th>
              <th>Statut</th>
              <th>Actions</th>
            </tr>
          </thead>
          <tbody>
            <% reservations.forEach((r) => { %>
              <tr>
                <td>
                  <%
                    const d = new Date(r.date)
                    const dateF = d.toLocaleDateString('fr-BE', { day: '2-digit', month: '2-digit', year: 'numeric' })
                  %>
                  <%= dateF %>
                </td>
                <td><%= (r.time_start || '').slice(0, 5) %></td>
                <td><%= r.table_code || 'Non assignée' %></td>
                <td><%= r.name %></td>
                <td><%= r.covers %></td>
                <td>
                  <span class="badge <%= r.source === 'phone' ? 'badge--phone' : 'badge--online' %>">
                    <%= r.source === 'phone' ? 'Téléphone' : 'En ligne' %>
                  </span>
                </td>
                <td>
                  <% if (r.status === 'pending') { %>
                    <span class="badge badge--pending">En attente</span>
                  <% } else if (r.status === 'confirmed') { %>
                    <span class="badge badge--confirmed">Confirmée</span>
                  <% } else { %>
                    <span class="badge badge--inactive">Annulée</span>
                  <% } %>
                </td>
                <td>
                  <% if (r.status === 'pending') { %>
                    <button class="btn btn-primary btn--tiny" data-res-status data-id="<%= r.id %>" data-status="confirmed">Confirmer</button>
                    <button class="btn btn-ghost btn--tiny" data-res-status data-id="<%= r.id %>" data-status="cancelled">Refuser</button>
                  <% } else if (r.status === 'confirmed') { %>
                    <button class="btn btn-ghost btn--tiny" data-res-status data-id="<%= r.id %>" data-status="cancelled">Annuler</button>
                  <% } else { %>
                    <button class="btn btn-ghost btn--tiny" data-res-status data-id="<%= r.id %>" data-status="confirmed">Reconfirmer</button>
                  <% } %>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    <% } %>
  </div>
  <script>
    (() => {
      const root = document.currentScript?.parentElement || document;
      const buttons = root.querySelectorAll('[data-res-status]');
      if (!buttons.length) return;
      buttons.forEach((btn) => {
        btn.addEventListener('click', async () => {
          const id = btn.getAttribute('data-id');
          const status = btn.getAttribute('data-status');
          if (!id || !status) return;
          btn.disabled = true;
          try {
            const res = await fetch(`/admin/api/reservations/${encodeURIComponent(id)}/status`, {
              method: 'PATCH',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ status })
            });
            if (!res.ok) {
              const data = await res.json().catch(() => ({}));
              throw new Error(data.message || `Erreur ${res.status}`);
            }
            window.location.reload();
          } catch (err) {
            alert(err.message || 'Action impossible.');
            btn.disabled = false;
          }
        });
      });
    })();
  </script>
</body>
</html>
