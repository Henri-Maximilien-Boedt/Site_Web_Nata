<%
  const path = typeof currentPath === 'string' ? currentPath : ''
  const isExactActive = (href) => path === href
  const isPrefixActive = (href) => path === href || path.startsWith(`${href}/`)
%>
<header class="topbar">
  <div class="brand-group">
    <a class="brand" href="/">
      <img src="/media/logo/IMG_3750-removebg-preview.png" alt="NATA Bar" class="brand-logo" />
    </a>
    <a href="https://www.instagram.com/nata.lln/" class="nav-instagram" target="_blank" rel="noreferrer noopener" aria-label="Instagram @nata.lln">
      <svg viewBox="0 0 24 24" fill="currentColor" focusable="false" aria-hidden="true">
        <path d="M7 3h10a4 4 0 0 1 4 4v10a4 4 0 0 1-4 4H7a4 4 0 0 1-4-4V7a4 4 0 0 1 4-4zm0 2a2 2 0 0 0-2 2v10a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2V7a2 2 0 0 0-2-2H7zm5 2.5A4.5 4.5 0 1 1 7.5 12 4.5 4.5 0 0 1 12 7.5zm0 2A2.5 2.5 0 1 0 14.5 12 2.5 2.5 0 0 0 12 9.5zm5.25-3.25a1.25 1.25 0 1 1-1.25 1.25 1.25 1.25 0 0 1 1.25-1.25z" />
      </svg>
    </a>
  </div>

  <button class="menu-btn" aria-label="Ouvrir le menu" aria-expanded="false" aria-controls="main-nav">☰</button>

  <nav class="nav" id="main-nav">
    <a href="/" class="<%= isExactActive('/') ? 'active' : '' %>">Accueil</a>
    <a href="/menu" class="<%= isPrefixActive('/menu') ? 'active' : '' %>">Menu</a>
    <a href="/evenements" class="<%= isPrefixActive('/evenements') ? 'active' : '' %>">Événements</a>
    <a href="/actualites" class="<%= isPrefixActive('/actualites') ? 'active' : '' %>">Actualités</a>
    <a href="/reservation" class="btn btn-primary nav-cta<%= isPrefixActive('/reservation') ? ' active' : '' %>">Réserver</a>
  </nav>
</header>
