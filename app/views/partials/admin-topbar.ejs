<%
  const adminPath = typeof currentSection === 'string' ? currentSection : ''
  const isSection = (s) => adminPath === s ? ' is-active' : ''
%>
<header class="admin-topbar">
  <a class="admin-topbar__brand" href="/admin">NATA <span>Admin</span></a>

  <button class="admin-topbar__hamburger" id="adminMenuBtn" aria-label="Menu admin" aria-expanded="false">☰</button>

  <nav class="admin-topbar__nav" id="adminNav">
    <a href="/admin" class="admin-topbar__link<%= isSection('dashboard') %>">Dashboard</a>
    <a href="/admin/reservations" class="admin-topbar__link<%= isSection('reservations') %>">Réservations</a>
    <a href="/admin/tables" class="admin-topbar__link<%= isSection('tables') %>">Tables</a>
    <a href="/admin/menu" class="admin-topbar__link<%= isSection('menu') %>">Menu</a>
    <a href="/admin/actualites" class="admin-topbar__link<%= isSection('actualites') %>">Actualités</a>
  </nav>

  <div class="admin-topbar__right">
    <a href="/" class="admin-topbar__site-link">← Site</a>
    <form method="POST" action="/admin/logout">
      <button type="submit" class="btn btn-ghost btn-sm">Déconnexion</button>
    </form>
  </div>
</header>
<script>
  (function () {
    const btn = document.getElementById('adminMenuBtn')
    const nav = document.getElementById('adminNav')
    if (btn && nav) {
      btn.addEventListener('click', () => {
        const open = nav.classList.toggle('is-open')
        btn.setAttribute('aria-expanded', String(open))
      })
    }
  })()
</script>
