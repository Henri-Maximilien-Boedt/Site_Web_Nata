<script>
  document.getElementById('year').textContent = new Date().getFullYear()

  const initCookieBanner = () => {
    const banner = document.querySelector('[data-cookie-banner]')
    const manageBtn = document.querySelector('[data-cookie-manage]')
    const acceptBtn = banner ? banner.querySelector('[data-cookie-accept]') : null
    const rejectBtn = banner ? banner.querySelector('[data-cookie-reject]') : null
    const STORAGE_KEY = 'nata_cookie_consent_v1'
    const COOKIE_NAME = 'nata_cookie_consent'
    const COOKIE_MAX_AGE = 60 * 60 * 24 * 30 // 30 jours
    if (!banner || !manageBtn || !acceptBtn || !rejectBtn) return

    const showBanner = () => {
      banner.classList.remove('is-hidden')
      manageBtn.classList.add('is-hidden')
    }

    const hideBanner = () => {
      banner.classList.add('is-hidden')
      manageBtn.classList.remove('is-hidden')
    }

    const setConsentCookie = (value, maxAge = COOKIE_MAX_AGE) => {
      document.cookie = `${COOKIE_NAME}=${encodeURIComponent(value)}; Max-Age=${maxAge}; Path=/; SameSite=Lax`
    }

    const clearConsentCookie = () => setConsentCookie('rejected', 0)

    const saveConsent = (value) => {
      try {
        localStorage.setItem(STORAGE_KEY, JSON.stringify({ value, ts: Date.now() }))
      } catch (_) {
        /* stockage plein ou privé : on ignore */
      }
      if (value === 'accepted' || value === 'rejected') setConsentCookie(value)
    }

    const getStored = () => {
      try {
        return JSON.parse(localStorage.getItem(STORAGE_KEY) || 'null')
      } catch {
        return null
      }
    }

    const stored = getStored()
    const ONE_DAY_MS = 24 * 60 * 60 * 1000
    const THIRTY_DAYS_MS = ONE_DAY_MS * 30
    const isExpired = stored?.ts ? (Date.now() - stored.ts) > THIRTY_DAYS_MS : true
    if (!stored || !stored.value || isExpired) {
      showBanner()
    } else {
      hideBanner()
    }

    acceptBtn.addEventListener('click', () => {
      saveConsent('accepted')
      hideBanner()
    })

    rejectBtn.addEventListener('click', () => {
      saveConsent('rejected')
      clearConsentCookie()
      hideBanner()
    })

    manageBtn.addEventListener('click', () => {
      showBanner()
    })
  }

  const start = () => {
    // si les éléments ne sont pas encore dans le DOM, on retente
    let attempts = 0
    const tryInit = () => {
      initCookieBanner()
      attempts += 1
      const ready = document.querySelector('[data-cookie-banner] [data-cookie-accept]')
      if (ready || attempts > 10) return
      setTimeout(tryInit, 50)
    }
    tryInit()
  }

  if (document.readyState === 'complete') {
    start()
  } else {
    window.addEventListener('load', start, { once: true })
  }
</script>
