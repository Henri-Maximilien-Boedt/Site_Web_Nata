<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Erreur - NATA Bar</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Manrope:wght@400;500;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/main.css">
</head>
<body>
  <div class="noise"></div>
  <%- include('partials/header', { currentPath: '' }) %>
  <main style="display: flex; align-items: center; justify-content: center; min-height: 60vh; flex-direction: column; text-align: center;">
    <h1 style="font-size: 2rem; color: var(--accent); margin-bottom: 1rem;">Erreur serveur</h1>
    <p style="font-size: 1.2rem; margin-bottom: 2rem;"><%= message %></p>
    <a href="/" class="btn btn-primary">Retour à l'accueil</a>
  </main>
  <%- include('partials/footer') %>
</body>
</html>
