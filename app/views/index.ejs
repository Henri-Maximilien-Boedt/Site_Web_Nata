<!DOCTYPE html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= title %></title>
    <meta name="description" content="<%= description %>" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Manrope:wght@400;500;700;800&display=swap"
      rel="stylesheet"
    />
    <link rel="stylesheet" href="/css/main.css" />
  </head>
  <body>
    <div class="noise"></div>

    <header class="topbar">
      <a class="brand" href="/">NATA Bar</a>
      <button class="menu-btn" aria-label="Ouvrir le menu">☰</button>
      <nav class="nav">
        <a href="/">Accueil</a>
        <a href="/menu">Menu</a>
        <a href="/reservation">Réservation</a>
        <a href="/admin/login">Admin</a>
        <a href="#contact">Contact</a>
      </nav>
    </header>

    <main>
      <section id="accueil" class="hero reveal">
        <div class="hero-copy">
          <p class="eyebrow">Korean Food & Bar</p>
          <h1>Saveurs Coréennes, Esprit de Bar.</h1>
          <p>
            Chez NATA Bar, découvre des plats coréens généreux, des recettes maison et une
            carte de boissons pensée pour partager de bons moments.
          </p>
          <div class="hero-actions">
            <a class="btn btn-primary" href="/menu">Voir le menu</a>
            <a class="btn btn-ghost" href="/reservation">Réserver</a>
          </div>
        </div>
        <div class="hero-media">
          <img src="/media/img/logo-nata.jpg" alt="Logo NATA Korean Food & Bar" />
        </div>
      </section>

      <section class="home-focus reveal">
        <a class="focus-card focus-card--events" href="/evenements">
          <p class="eyebrow">Privatisation</p>
          <h2>NOS EVENEMENTS</h2>
          <p class="focus-card__hint">Clique ici pour découvrir nos formules et demander un devis</p>
        </a>

        <article class="focus-card focus-card--truck">
          <p class="eyebrow">NATA Street Vibes</p>
          <h2>NOS FOOD TRUCK</h2>
          <p class="focus-card__hint">Restaurant ou food truck selon votre événement</p>
        </article>

        <a class="focus-card focus-card--menu" href="/menu">
          <p class="eyebrow">Découvrir</p>
          <h2>NATA BAR MENU</h2>
          <p class="focus-card__hint">Clique pour accéder à toute la carte</p>
        </a>
      </section>

      <section id="contact" class="contact reveal">
        <div>
          <p class="eyebrow">Contact</p>
          <h2>Réserve ta table</h2>
          <p>Ouvert le : <br />Lundi de 18:00–22:00 et du<br />mardi au samedi, 12:00–14:30 18:00–22:00.</p>
          <p>Grand-Place 51, 1348 Ottignies-Louvain-la-Neuve</p>
          <p>Tél: 01 23 45 67 89</p>
        </div>
        <form class="booking-form" action="/reservation" method="post">
          <label>
            Nom
            <input type="text" name="name" placeholder="Ton nom" required />
          </label>
          <label>
            Email
            <input type="email" name="email" placeholder="nom@email.com" required />
          </label>
          <label>
            Téléphone
            <input type="tel" name="phone" placeholder="Ex: 0470 12 34 56" required />
          </label>
          <label>
            Nombre de personnes
            <input type="number" name="people" min="1" max="10" placeholder="Ex: 4" required />
          </label>
          <label>
            Date
            <div class="date-picker" data-date-picker>
              <input type="hidden" name="date" data-date-value />
              <input
                type="text"
                class="date-trigger"
                data-date-trigger
                placeholder="Cliquez pour choisir une date"
                readonly
                required
              />
              <p class="date-help">Cliquez sur le champ pour ouvrir le sélecteur grand format.</p>
            </div>
          </label>
          <label>
            Heure
            <div class="time-picker" data-time-picker>
              <input type="hidden" name="time" data-time-value />
              <input
                type="text"
                class="time-trigger"
                data-time-trigger
                placeholder="Sélectionnez d'abord une date"
                readonly
                required
              />
              <p class="date-help"></p>
            </div>
          </label>
          <label>
            Table
            <div class="table-picker" data-table-picker>
              <input type="hidden" name="tableId" data-table-value />
              <input
                type="text"
                class="table-trigger"
                data-table-trigger
                placeholder="Choisis d'abord une date et une heure"
                readonly
                required
              />
              <p class="date-help">Plan interactif: 5 tables de 2, 4 tables de 4, 1 table de 10.</p>
            </div>
          </label>
          <label>
            Message
            <textarea name="message" rows="4" placeholder="Nombre de personnes, heure..."></textarea>
          </label>
          <button type="submit" class="btn btn-primary">Envoyer</button>
        </form>
      </section>
    </main>

    <footer>
      <p>© <span id="year"></span> NATA Bar. Tous droits réservés.</p>
    </footer>

    <textarea id="nata-state" hidden><%- typeof clientStateJson !== 'undefined' ? clientStateJson : '{}' %></textarea>
    <script src="/js/app.js"></script>
  </body>
</html>
